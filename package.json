{
  "name": "nexusmon-void-theme",
  "displayName": "NEXUSMON Void",
  "description": "A sovereign VS Code theme for the Shadow Monarch. Jack in to the Digital World with deep void-darkness, cyber-neon Navis, and systemic shadows.",
  "version": "1.1.0",
  "publisher": "darthvpirateking-afk",
  "repository": {
    "type": "git",
    "url": "https://github.com/darthvpirateking-afk/nexusmon-void-theme.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "NEXUSMON Sovereign",
        "uiTheme": "vs-dark",
        "path": "./themes/nexusmon-sovereign-color-theme.json"
      },
      {
        "label": "NEXUSMON Void",
        "uiTheme": "vs-dark",
        "path": "./themes/nexusmon-void-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "nexusmon.arise",
        "title": "NEXUSMON: Arise"
      },
      {
        "command": "nexusmon.jackIn",
        "title": "NEXUSMON: Jack In"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.18.0",
    "typescript": "^5.1.0"
  },
  "galleryBanner": {
    "color": "#080B12",
    "theme": "dark"
  },
  "keywords": [
    "nexusmon",
    "dark",
    "solo-leveling",
    "digimon",
    "megaman-battle-network",
    "pet",
    "arise",
    "jack-in",
    "code-crown",
    "shadows"
  ],
  "license": "MIT"
}
