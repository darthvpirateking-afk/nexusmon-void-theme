{
  "$schema": "vscode://schemas/color-theme",
  "name": "NEXUSMON Void",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#05070D",
    "editor.foreground": "#E0E5EC",
    "editor.lineHighlightBackground": "#0B101A60",
    "editor.lineHighlightBorder": "#00F0FF20",
    "editor.selectionBackground": "#00F0FF28",
    "editor.selectionHighlightBackground": "#00F0FF15",
    "editor.inactiveSelectionBackground": "#00F0FF10",
    "editor.wordHighlightBackground": "#14E8C220",
    "editor.wordHighlightStrongBackground": "#FFBB0025",
    "editor.findMatchBackground": "#00F0FF40",
    "editor.findMatchHighlightBackground": "#FFBB0020",
    "editor.rangeHighlightBackground": "#FFBB0010",
    "editorCursor.foreground": "#00F0FF",
    "editorWhitespace.foreground": "#1A2633",
    "editorIndentGuide.background1": "#1A2633",
    "editorIndentGuide.activeBackground1": "#00F0FF50",
    "editorLineNumber.foreground": "#42556B",
    "editorLineNumber.activeForeground": "#FFBB00",
    "editorBracketMatch.background": "#00F0FF20",
    "editorBracketMatch.border": "#00F0FF80",
    "editorRuler.foreground": "#1A2633",
    "editorOverviewRuler.border": "#05070D00",
    "editorGutter.addedBackground": "#00FF88",
    "editorGutter.modifiedBackground": "#FFBB00",
    "editorGutter.deletedBackground": "#FF0033",
    "editorBracketHighlight.foreground1": "#00F0FF",
    "editorBracketHighlight.foreground2": "#00FF88",
    "editorBracketHighlight.foreground3": "#FFBB00",
    "editorBracketHighlight.foreground4": "#8A2BE2",
    "editorBracketHighlight.foreground5": "#FF00FF",
    "editorBracketHighlight.foreground6": "#FF0033",
    "diffEditor.insertedTextBackground": "#00FF8815",
    "diffEditor.removedTextBackground": "#FF003315",
    "scrollbar.shadow": "#00000080",
    "scrollbarSlider.background": "#00F0FF20",
    "scrollbarSlider.hoverBackground": "#00F0FF40",
    "scrollbarSlider.activeBackground": "#00F0FF60",
    "minimap.background": "#05070D",
    "minimap.selectionHighlight": "#00F0FF50",
    "sideBar.background": "#070A12",
    "sideBar.foreground": "#C3D1DF",
    "sideBar.border": "#121924",
    "sideBarTitle.foreground": "#00F0FF",
    "sideBarSectionHeader.background": "#05070D",
    "sideBarSectionHeader.foreground": "#FFBB00",
    "sideBarSectionHeader.border": "#121924",
    "activityBar.background": "#05070D",
    "activityBar.foreground": "#00F0FF",
    "activityBar.inactiveForeground": "#42556B",
    "activityBar.border": "#121924",
    "activityBar.activeBorder": "#00F0FF",
    "activityBarBadge.background": "#FFBB00",
    "activityBarBadge.foreground": "#05070D",
    "titleBar.activeBackground": "#05070D",
    "titleBar.activeForeground": "#E0E5EC",
    "titleBar.inactiveBackground": "#0B101A",
    "titleBar.inactiveForeground": "#42556B",
    "titleBar.border": "#121924",
    "statusBar.background": "#0B101A",
    "statusBar.foreground": "#E0E5EC",
    "statusBar.border": "#121924",
    "statusBar.debuggingBackground": "#8A2BE2",
    "statusBar.debuggingForeground": "#E0E5EC",
    "statusBar.noFolderBackground": "#05070D",
    "editorGroupHeader.tabsBackground": "#05070D",
    "editorGroupHeader.tabsBorder": "#121924",
    "tab.activeBackground": "#0B101A",
    "tab.activeForeground": "#FFBB00",
    "tab.activeBorderTop": "#00F0FF",
    "tab.activeBorder": "#05070D00",
    "tab.inactiveBackground": "#05070D",
    "tab.inactiveForeground": "#42556B",
    "tab.hoverBackground": "#0B101A",
    "tab.border": "#12192440",
    "panel.background": "#0B101A",
    "panel.border": "#121924",
    "panelTitle.activeBorder": "#00F0FF",
    "panelTitle.activeForeground": "#FFBB00",
    "panelTitle.inactiveForeground": "#42556B",
    "terminal.background": "#05070D",
    "terminal.foreground": "#E0E5EC",
    "terminal.ansiBlack": "#05070D",
    "terminal.ansiRed": "#FF0033",
    "terminal.ansiGreen": "#00FF88",
    "terminal.ansiYellow": "#FFBB00",
    "terminal.ansiBlue": "#00F0FF",
    "terminal.ansiMagenta": "#FF00FF",
    "terminal.ansiCyan": "#14E8C2",
    "terminal.ansiWhite": "#E0E5EC",
    "terminal.ansiBrightBlack": "#42556B",
    "terminal.ansiBrightRed": "#FF6E8F",
    "terminal.ansiBrightGreen": "#8DF5E1",
    "terminal.ansiBrightYellow": "#FFE08A",
    "terminal.ansiBrightBlue": "#7BE7FF",
    "terminal.ansiBrightMagenta": "#F28BFF",
    "terminal.ansiBrightCyan": "#A5F5E9",
    "terminal.ansiBrightWhite": "#FFFFFF",
    "terminalCursor.foreground": "#00F0FF",
    "terminal.selectionBackground": "#00F0FF30",
    "input.background": "#0B101A",
    "input.foreground": "#E0E5EC",
    "input.border": "#121924",
    "input.placeholderForeground": "#42556B",
    "list.activeSelectionBackground": "#00F0FF25",
    "list.activeSelectionForeground": "#FFFFFF",
    "list.inactiveSelectionBackground": "#00F0FF12",
    "list.hoverBackground": "#0B101A80",
    "list.highlightForeground": "#FFBB00",
    "quickInput.background": "#0B101A",
    "quickInput.foreground": "#E0E5EC",
    "quickInputList.focusBackground": "#00F0FF25",
    "badge.background": "#FFBB00",
    "badge.foreground": "#05070D",
    "button.background": "#0D2231",
    "button.foreground": "#E0E5EC",
    "button.hoverBackground": "#12354A",
    "button.secondaryBackground": "#0B101A",
    "button.secondaryForeground": "#E0E5EC"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#42556B", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "keyword.control", "storage.modifier"],
      "settings": { "foreground": "#8A2BE2" }
    },
    {
      "scope": ["keyword.control.flow", "keyword.control.return", "keyword.control.exception"],
      "settings": { "foreground": "#FF00FF" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#00F0FF" }
    },
    {
      "scope": ["storage.type"],
      "settings": { "foreground": "#00F0FF" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#00FF88" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#FFBB00" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#FFBB00" }
    },
    {
      "scope": ["constant.language"],
      "settings": { "foreground": "#FFBB00", "fontStyle": "bold" }
    },
    {
      "scope": ["constant.other", "constant.character.escape"],
      "settings": { "foreground": "#14E8C2" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#E0E5EC" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#A4B5C7" }
    },
    {
      "scope": ["variable.language.this", "variable.language.self"],
      "settings": { "foreground": "#FF00FF", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#00F0FF" }
    },
    {
      "scope": ["entity.name.function.decorator", "meta.decorator"],
      "settings": { "foreground": "#FF00FF" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.class"],
      "settings": { "foreground": "#8A2BE2" }
    },
    {
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#14E8C2" }
    },
    {
      "scope": ["entity.name.type.enum", "variable.other.enummember"],
      "settings": { "foreground": "#FFBB00" }
    },
    {
      "scope": ["variable.other.property", "meta.object-literal.key"],
      "settings": { "foreground": "#00FF88" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#FF00FF" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#FFBB00", "fontStyle": "italic" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#42556B" }
    },
    {
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#00F0FF" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#FFBB00", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#FFBB00", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#8A2BE2", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw"],
      "settings": { "foreground": "#00FF88" }
    },
    {
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.as"],
      "settings": { "foreground": "#FF00FF" }
    },
    {
      "scope": ["invalid.illegal"],
      "settings": { "foreground": "#FF0033" }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#FF6E8F", "fontStyle": "strikethrough" }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#00F0FF",
    "type": "#8A2BE2",
    "class": "#8A2BE2",
    "enum": "#FFBB00",
    "interface": "#14E8C2",
    "struct": "#00F0FF",
    "typeParameter": "#FFBB00",
    "parameter": "#A4B5C7",
    "variable": "#E0E5EC",
    "property": "#00FF88",
    "enumMember": "#FFBB00",
    "function": "#00F0FF",
    "method": "#00F0FF",
    "macro": "#FF00FF",
    "keyword": "#8A2BE2",
    "comment": { "foreground": "#42556B", "fontStyle": "italic" },
    "string": "#00FF88",
    "number": "#FFBB00",
    "regexp": "#FFBB00",
    "operator": "#00F0FF",
    "decorator": "#FF00FF",
    "selfKeyword": { "foreground": "#FF00FF", "fontStyle": "italic" }
  }
}
